/*
.DS_Store

# Included list
!ghostty/
!nvim/
!tmux/
!zsh/
!notifier/
!.ideavimrc
!claude/
!ai/
!codex/
!.gitignore
!README.md

# nvim
nvim/.claude/
nvim/*.log
nvim/lua/private/*
!nvim/lua/private/README.md

# tmux
tmux/plugins/

# zsh
zsh/*
!zsh/.zshrc
!zsh/custom
zsh/**/.git

# claude
claude/hooks/.rtk-hook.sha256
claude/memory/private/
claude/MEMORY.private.md
claude/*.lock
claude/*.tmp
claude/.claude

# notifier
notifier/macos/AgentNotifier
notifier/linux/agent-notifier
notifier/linux/agent-notifier-send

# codex — site-local sensitive patterns (never committed)
codex/scripts/sensitive-patterns.local
