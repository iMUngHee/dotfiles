{
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "70",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false"
  },
  "permissions": {
    "allow": [
      "Bash(bun run*)",
      "Bash(bun test*)",
      "Bash(cargo build*)",
      "Bash(cargo test*)",
      "Bash(ccusage*)",
      "Bash(cd*)",
      "Bash(chmod*)",
      "Bash(claude*)",
      "Bash(cp*)",
      "Bash(echo*)",
      "Bash(gh api*)",
      "Bash(gh repo*)",
      "Bash(gh search*)",
      "Bash(git blame*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git status*)",
      "Bash(go build*)",
      "Bash(go test*)",
      "Bash(ls*)",
      "Bash(npm info*)",
      "Bash(npm list*)",
      "Bash(npm run*)",
      "Bash(nvim*)",
      "Bash(open*)",
      "Bash(pbpaste*)",
      "Bash(pkill -x ClaudeNotifier*)",
      "Bash(pnpm build*)",
      "Bash(pnpm run*)",
      "Bash(pnpm test*)",
      "Bash(printf*)",
      "Bash(python3*)",
      "Bash(rtk cc-economics*)",
      "Bash(rtk discover*)",
      "Bash(rtk gain*)",
      "Bash(rtk hook-audit*)",
      "Bash(rtk init*)",
      "Bash(rtk learn*)",
      "Bash(rtk session*)",
      "Bash(rtk verify*)",
      "Bash(which*)",
      "Glob",
      "Grep",
      "Read",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:claude.ai)",
      "WebFetch(domain:claude.com)",
      "WebFetch(domain:deepwiki.com)",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:www-cdn.anthropic.com)",
      "WebFetch(domain:www.anthropic.com)",
      "WebFetch(domain:www.claude.com)",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:www.rtk-ai.app)",
      "WebFetch(domain:x.com)",
      "WebSearch"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.aws/**)",
      "Read(~/.kube/**)",
      "Read(~/.docker/config.json)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.git-credentials)",
      "Read(~/.bash_history)",
      "Read(~/.zsh_history)",
      "Read(~/.netrc)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/protect-files.sh"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "rate_limit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/on-rate-limit.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/compact-restore.sh"
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/check-quota-switch.sh"
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/check-quota-switch.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notify.sh stop",
            "timeout": 10000
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notify.sh approval",
            "timeout": 10000
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notify.sh approval",
            "timeout": 10000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash|Agent|NotebookEdit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/context-monitor.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/typecheck-after-edit.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/log-tool-failure.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/prompt-guard.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "lua-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": true,
    "kotlin-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "language": "한국어",
  "spinnerTipsEnabled": false,
  "effortLevel": "high",
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true,
    "failIfUnavailable": true
  },
  "cleanupPeriodDays": 14
}
