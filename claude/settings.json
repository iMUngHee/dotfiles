{
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "70",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false"
  },
  "permissions": {
    "allow": [
      "Bash(awk*)",
      "Bash(basename*)",
      "Bash(brew info*)",
      "Bash(brew list*)",
      "Bash(bun run*)",
      "Bash(bun test*)",
      "Bash(cargo build*)",
      "Bash(cargo test*)",
      "Bash(ccusage*)",
      "Bash(cd*)",
      "Bash(chmod*)",
      "Bash(claude*)",
      "Bash(cp*)",
      "Bash(curl*)",
      "Bash(date*)",
      "Bash(diff*)",
      "Bash(dirname*)",
      "Bash(du*)",
      "Bash(echo*)",
      "Bash(env*)",
      "Bash(file*)",
      "Bash(find*)",
      "Bash(gh api*)",
      "Bash(gh repo*)",
      "Bash(gh search*)",
      "Bash(git blame*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git diff*)",
      "Bash(git fetch*)",
      "Bash(git log*)",
      "Bash(git ls-files*)",
      "Bash(git remote*)",
      "Bash(git rev-parse*)",
      "Bash(git show*)",
      "Bash(git stash list*)",
      "Bash(git stash show*)",
      "Bash(git status*)",
      "Bash(git switch*)",
      "Bash(git tag*)",
      "Bash(go build*)",
      "Bash(go test*)",
      "Bash(go version*)",
      "Bash(jq*)",
      "Bash(ls*)",
      "Bash(mkdir*)",
      "Bash(node --version*)",
      "Bash(npm audit*)",
      "Bash(npm info*)",
      "Bash(npm list*)",
      "Bash(npm run*)",
      "Bash(nvim*)",
      "Bash(open*)",
      "Bash(pbpaste*)",
      "Bash(pkill -x ClaudeNotifier*)",
      "Bash(pnpm build*)",
      "Bash(pnpm run*)",
      "Bash(pnpm test*)",
      "Bash(printf*)",
      "Bash(pwd*)",
      "Bash(python3*)",
      "Bash(readlink*)",
      "Bash(rtk cc-economics*)",
      "Bash(rtk discover*)",
      "Bash(rtk gain*)",
      "Bash(rtk hook-audit*)",
      "Bash(rtk init*)",
      "Bash(rtk learn*)",
      "Bash(rtk session*)",
      "Bash(rtk verify*)",
      "Bash(rustc --version*)",
      "Bash(sed*)",
      "Bash(sort*)",
      "Bash(stat*)",
      "Bash(touch*)",
      "Bash(tree*)",
      "Bash(uname*)",
      "Bash(uniq*)",
      "Bash(wc*)",
      "Bash(wget*)",
      "Bash(which*)",
      "Bash(whoami*)",
      "Edit",
      "Glob",
      "Grep",
      "Read",
      "WebFetch",
      "WebSearch",
      "Write"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.aws/**)",
      "Read(~/.kube/**)",
      "Read(~/.docker/config.json)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.git-credentials)",
      "Read(~/.bash_history)",
      "Read(~/.zsh_history)",
      "Read(~/.netrc)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/secrets/**)",
      "Write(**/credentials/**)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/secrets/**)",
      "Edit(**/credentials/**)"
    ],
    "disableBypassPermissionsMode": "disable",
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/rtk-rewrite.sh",
            "statusMessage": "Optimizing command..."
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/protect-files.sh",
            "statusMessage": "Checking file safety..."
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "rate_limit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/on-rate-limit.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/compact-restore.sh"
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/check-quota-switch.sh"
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/check-quota-switch.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/stop-handler.sh",
            "timeout": 45000,
            "statusMessage": "Running type checker..."
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notify.sh approval",
            "timeout": 10000
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notify.sh approval",
            "timeout": 10000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/post-edit-pipeline.sh",
            "statusMessage": "Formatting & checking..."
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash|Agent|NotebookEdit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/context-monitor.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/prompt-guard.sh",
            "statusMessage": "Scanning for secrets..."
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/log-tool-failure.sh",
            "statusMessage": "Logging tool failure..."
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/log-instructions.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/subagent-stop-reminder.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "lua-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": true,
    "kotlin-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "language": "한국어",
  "spinnerTipsEnabled": false,
  "effortLevel": "high",
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true,
    "failIfUnavailable": true
  },
  "cleanupPeriodDays": 14,
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "alwaysThinkingEnabled": true,
  "includeGitInstructions": false
}
